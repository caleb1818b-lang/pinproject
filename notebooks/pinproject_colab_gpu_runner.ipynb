      "source": [
        "# Disney Pin Catalog Parser \u2014 Google Colab GPU Runner\n",
        "\n",
        "This notebook clones the public GitHub repository, installs the parser, optionally starts Ollama for GPU vision extraction, runs the existing `run_parser.sh`, saves the final Excel workbook to Google Drive, and downloads a copy.\n",
        "\n",
        "**Runtime:** In Colab choose **Runtime \u2192 Change runtime type \u2192 GPU** before running all cells when `USE_OLLAMA_VISION` is enabled.\n"
        "This notebook clones the public GitHub repository, installs the parser, optionally starts Ollama for GPU vision extraction, runs the existing `run_parser.sh`, and downloads the final Excel workbook.\n",
        "\n",
        "**Runtime:** In Colab choose **Runtime \u2192 Change runtime type \u2192 GPU** before running all cells.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 1. Configure the public repo, run mode, and Google Drive output\n",
        "#@title 1. Configure the public repo and run mode\n",
        "REPO_URL = \"https://github.com/YOUR-USERNAME/pinproject.git\"  #@param {type:\"string\"}\n",
        "BRANCH = \"main\"  #@param {type:\"string\"}\n",
        "USE_OLLAMA_VISION = False  #@param {type:\"boolean\"}\n",
        "OLLAMA_MODEL = \"qwen2.5vl:3b\"  #@param {type:\"string\"}\n",
        "SAVE_TO_GOOGLE_DRIVE = True  #@param {type:\"boolean\"}\n",
        "DRIVE_OUTPUT_DIR = \"/content/drive/MyDrive/pinproject-output\"  #@param {type:\"string\"}\n",
        "\n",
        "# Fast mode is deterministic and usually finishes quickly.\n",
        "# Turn USE_OLLAMA_VISION on only when you need GPU vision cleanup and have selected a GPU runtime.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 2. Check GPU and clone/update the repository\n",
        "import os, shutil, subprocess, textwrap\n",
        "from pathlib import Path\n",
        "\n",
        "workdir = Path('/content/pinproject')\n",
        "if workdir.exists():\n",
        "    shutil.rmtree(workdir)\n",
        "subprocess.run(['git', 'clone', '--depth', '1', '--branch', BRANCH, REPO_URL, str(workdir)], check=True)\n",
        "os.chdir(workdir)\n",
        "print('Repository ready at', workdir)\n",
        "subprocess.run(['nvidia-smi'], check=False)\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 3. Mount Google Drive and choose output folder\n",
        "from pathlib import Path\n",
        "if SAVE_TO_GOOGLE_DRIVE:\n",
        "    from google.colab import drive\n",
        "    drive.mount('/content/drive')\n",
        "    output_dir = Path(DRIVE_OUTPUT_DIR)\n",
        "else:\n",
        "    output_dir = Path('/content/pinproject/output')\n",
        "output_dir.mkdir(parents=True, exist_ok=True)\n",
        "print('Workbook will be saved to:', output_dir / 'disney-pin-catalogue.xlsx')\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 4. Install Python dependencies\n",
        "#@title 3. Install Python dependencies\n",
        "import subprocess, sys\n",
        "subprocess.run([sys.executable, '-m', 'pip', 'install', '--quiet', '--upgrade', 'pip'], check=True)\n",
        "subprocess.run([sys.executable, '-m', 'pip', 'install', '--quiet', '-e', '.'], check=True)\n",
        "print('Python package installed')\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 5. Optional: install and start Ollama for GPU vision mode\n",
        "#@title 4. Optional: install and start Ollama for GPU vision mode\n",
        "import os, subprocess, time, shutil\n",
        "\n",
        "if USE_OLLAMA_VISION:\n",
        "    if shutil.which('ollama') is None:\n",
        "        subprocess.run('curl -fsSL https://ollama.com/install.sh | sh', shell=True, check=True)\n",
        "    server = subprocess.Popen(['ollama', 'serve'], stdout=subprocess.DEVNULL, stderr=subprocess.STDOUT)\n",
        "    time.sleep(8)\n",
        "    subprocess.run(['ollama', 'pull', OLLAMA_MODEL], check=True)\n",
        "    os.environ['PIN_USE_OLLAMA'] = '1'\n",
        "    os.environ['PIN_OLLAMA_MODEL'] = OLLAMA_MODEL\n",
        "    os.environ['PIN_OLLAMA_TIMEOUT'] = '1800'\n",
        "    print('Ollama vision mode ready with', OLLAMA_MODEL)\n",
        "else:\n",
        "    os.environ['PIN_USE_OLLAMA'] = '0'\n",
        "    print('Fast deterministic mode selected; skipping Ollama install.')\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 6. Add or inspect PDFs\n",
        "#@title 5. Add or inspect PDFs\n",
        "from pathlib import Path\n",
        "pdf_dir = Path('catalog-pdfs')\n",
        "pdf_dir.mkdir(exist_ok=True)\n",
        "pdfs = sorted(pdf_dir.glob('*.pdf')) + sorted(pdf_dir.glob('*.PDF'))\n",
        "print(f'Found {len(pdfs)} PDFs in {pdf_dir}:')\n",
        "for pdf in pdfs:\n",
        "    print(' -', pdf)\n",
        "\n",
        "# If your public repo does not include PDFs, upload them into /content/pinproject/catalog-pdfs\n",
        "# with the Colab file browser, then rerun this cell.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 7. Run the existing shell file and create the Excel output\n",
        "import os, subprocess\n",
        "env = os.environ.copy()\n",
        "env['PYTHON_BIN'] = 'python3'\n",
        "env['OUTPUT_DIR'] = str(output_dir)\n",
        "#@title 6. Run the existing shell file and create the Excel output\n",
        "import os, subprocess\n",
        "env = os.environ.copy()\n",
        "env['PYTHON_BIN'] = 'python3'\n",
        "env['OUTPUT_DIR'] = '/content/pinproject/output'\n",
        "subprocess.run(['bash', 'run_parser.sh'], check=True, env=env)\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 8. Download the final workbook\n",
        "from pathlib import Path\n",
        "from google.colab import files\n",
        "workbook = output_dir / 'disney-pin-catalogue.xlsx'\n",
        "#@title 7. Download the final workbook\n",
        "from pathlib import Path\n",
        "from google.colab import files\n",
        "workbook = Path('/content/pinproject/output/disney-pin-catalogue.xlsx')\n",
        "if not workbook.exists():\n",
        "    raise FileNotFoundError(workbook)\n",
        "print('Final workbook:', workbook, workbook.stat().st_size, 'bytes')\n",
        "files.download(str(workbook))\n"
      ]
    }
